<div class="container-xxl flex-grow-1 container-p-y">
             <div class="container-fluid mt-4">

  <h2 class="mb-4">Centro de Reportes</h2>
  <span>¿Hay un animalito en problemas? Genera tu reporte para una atención rápida.</span>
  <hr>

    <div class="row">
    <!-- Reportes -->
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <h5>Reportes</h5>
          <p class="text-muted">Generar un nuevo reporte</p>
          <button id="btnGenerarReporte" class="btn btn-primary">
            Crear Reporte
          </button>
        </div>
      </div>
    </div>

    <!-- ONG -->
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <h5>Casos Generados</h5>
          <p class="text-muted">Seguimiento de Casos</p>
          <button class="btn btn-secondary" disabled>
            Próximamente
          </button>
        </div>
      </div>
    </div>

    <!-- Organizaciones -->
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <h5>Organizaciones</h5>
          <p class="text-muted">Organizaciones Cerca</p>
          <button class="btn btn-secondary" disabled>
            Próximamente
          </button>
        </div>
      </div>
    </div>

  </div>

     <div class="row d-none" id="generarReporte">
                <div class="col-md-12">

                  <div class="card mb-4">
                    <h5 class="card-header">Genera tu Nuevo Reporte</h5>
                    <!-- Account -->
                 
                    <hr class="my-0" />
                    <div class="card-body">
                      <form id="formGenerarReporte" enctype="multipart/form-data">

  <div class="row">

    <!-- 📸 EVIDENCIA -->
    <div class="col-md-12 mb-3 text-center">
      <label class="form-label d-block">SUBE LA EVIDENCIA DEL CASO</label>
      <span class="mb-3 d-block">Nos permite visualizar la urgencia del reporte y define nuestro accionar :)</span>
      
      <br>
      <input
  type="file"
  id="evidencias"
  name="evidencias"
  multiple
  accept="image/*,video/*"
  hidden
/>

      <button type="button" class="btn btn-outline-primary btn-sm" id="btnSeleccionarImagen">
        Seleccionar imagen
      </button>

<div id="previewContainer" class="d-flex flex-wrap"></div>
      
    </div>

  
    <div class="mb-3 col-md-6">
      <label class="form-label">DESCRIPCIÓN DEL CASO</label>
      <input class="form-control" type="text" id="descripcion" required />
    </div>

 
    <div class="mb-3 col-md-6">
      <label class="form-label">URGENCIA</label>
      <select class="form-control" id="urgencia">
        <option value="baja">Baja</option>
        <option value="media">Media</option>
        <option value="alta">Alta</option>
      </select>
    </div>


    <div class="mb-3 col-md-6">
      <label class="form-label">PROVINCIA</label>
      <input class="form-control" type="text" id="provincia" required />
    </div>

  
    <div class="mb-3 col-md-6">
      <label class="form-label">UBICACIÓN</label>
      <input class="form-control" type="text" id="ubicacion" required />
    </div>

  </div>

  <div class="mt-2">
    <button type="submit" class="btn btn-primary">Generar Reporte</button>
  </div>

</form>
                    </div>
                  
                  </div>
                 
                </div>
              </div>

  <div class="card d-none" id="seguimientoCasos">
    <div class="card-body">

      <table class="table align-middle">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Email</th>
            <th>Teléfono</th>
            <th>Rol</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>

        <tbody id="tablaUsuarios"></tbody>

      </table>

    </div>
  </div>

</div>



    <script src="/assets/vendor/libs/jquery/jquery.js"></script>
<script src="/assets/js/reportes.js"></script>
</div>