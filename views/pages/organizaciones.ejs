<div class="container-xxl flex-grow-1 container-p-y">
             <div class="container-fluid mt-4">

  <h2 class="mb-4">ORGANIZACIONES ALIADAS</h2>
  <span>Conoce las organizaciones aliadas de FaunaLink</span>
  <hr>

    <div class="row">
    <!-- Reportes -->
    <div class="col-lg-6 col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <h5>Reportes</h5>
          <p class="text-muted">Generar un nuevo reporte</p>
          <button id="btnGenerarReporte" class="btn btn-primary">
            Crear Reporte
          </button>
        </div>
      </div>
    </div>

    <!-- ONG -->
    <div class="col-lg-6 col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <h5>Casos Generados</h5>
          <p class="text-muted">Seguimiento de Casos</p>
          <button id="verMisReportes" class="btn btn-primary" >
            Ver
          </button>
        </div>
      </div>
    </div>



  </div>

     <div class="row d-none" id="generarReporte">
                <div class="col-md-12">

                  <div class="card mb-4">
                    <h5 class="card-header">Genera tu Nuevo Reporte</h5>
                    <!-- Account -->
                 
                    <hr class="my-0" />
                    <div class="card-body">
                      <form id="formGenerarReporte" enctype="multipart/form-data">

  <div class="row">

    <!-- 📸 EVIDENCIA -->
    <div class="col-md-12 mb-3 text-center">
      <label class="form-label d-block">SUBE LA EVIDENCIA DEL CASO</label>
      <span class="mb-3 d-block">Nos permite visualizar la urgencia del reporte y define nuestro accionar :)</span>
      
      <br>
      <input
  type="file"
  id="evidencias"
  name="evidencias"
  multiple
  accept="image/*,video/*"
  hidden
/>

      <button type="button" class="btn btn-outline-primary btn-sm" id="btnSeleccionarImagen">
        Seleccionar imagen
      </button>

<div id="previewContainer" class="d-flex flex-wrap"></div>
      
    </div>

  
    <div class="mb-3 col-md-6">
      <label class="form-label">DESCRIPCIÓN DEL CASO</label>
      <input class="form-control" type="text" id="descripcion" required />
    </div>

 
    <div class="mb-3 col-md-6">
      <label class="form-label">URGENCIA</label>
      <select class="form-control" id="urgencia">
        <option value="baja">Baja</option>
        <option value="media">Media</option>
        <option value="alta">Alta</option>
      </select>
    </div>


<div class="mb-3 col-md-6">
  <label class="form-label">PROVINCIA</label>
  <select class="form-control" id="provinciaReporte">
    <option value="San José">San José</option>
    <option value="Alajuela">Alajuela</option>
    <option value="Cartago">Cartago</option>
    <option value="Heredia">Heredia</option>
    <option value="Guanacaste">Guanacaste</option>
    <option value="Puntarenas">Puntarenas</option>
    <option value="Limón">Limón</option>
  </select>
</div>

    <div class="mb-3 col-md-6">
      <label class="form-label">UBICACIÓN</label>
      <input class="form-control" type="text" id="ubicacionReporte" required />
    </div>

  </div>

  <div class="mt-2">
    <button type="submit" class="btn btn-primary">Generar Reporte</button>
  </div>

</form>
                    </div>
                  
                  </div>
                 
                </div>
              </div>

  <div class="card d-none" id="seguimientoCasos">
    <div class="card-body">

      <table class="table align-middle">
        <thead>
          <tr>
            <th>Descripción del Caso</th>
            <th>Ubicación</th>
            <th>Urgencia</th>
            <th>Asignado a</th>
            <th>Estado</th>
            <th>Fecha</th>
            <th>Acciones</th>
          </tr>
        </thead>

        <tbody id="tablaMisReportes"></tbody>

      </table>

    </div>
  </div>


<div class="modal fade" id="modalDetalleReporte" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Detalle del Reporte 🐾</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <p><strong>Descripción:</strong> <span id="detalleDescripcion"></span></p>
        <p><strong>Ubicación:</strong> <span id="detalleUbicacion"></span></p>
        <p><strong>Provincia:</strong> <span id="detalleProvincia"></span></p>
        <p><strong>Urgencia:</strong> <span id="detalleUrgencia"></span></p>
        <p><strong>Estado:</strong> <span id="detalleEstado"></span></p>

        <hr>

        <h6>Evidencias actuales</h6>
        <div id="contenedorEvidenciasActuales" class="d-flex flex-wrap"></div>

        <hr>

        <h6 class="nuevasEvidencias">Agregar nuevas evidencias</h6>
        <input type="file" id="nuevasEvidencias" multiple accept="image/*,video/*" class="form-control nuevasEvidencias">

      </div>

      <div class="modal-footer">
        <button id="btnEditarDatos" class="btn btn-primary d-none">Editar Información</button>
        <button id="btnEditarReporte" class="btn btn-warning d-none">Guardar Cambios</button>
        <button id="btnCancelarReporte" class="btn btn-danger d-none">Cancelar Reporte</button>
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
      </div>

    </div>
  </div>
</div>

</div>



<script src="/assets/vendor/libs/jquery/jquery.js"></script>
<script src="/assets/js/reportes.js"></script>
</div>