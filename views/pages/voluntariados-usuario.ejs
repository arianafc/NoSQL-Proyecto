<style>
  .vol-container {
    padding: 32px;
    max-width: 1100px;
  }

  .vol-titulo {
    font-size: 1.6rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: .5px;
  }

  .vol-subtitulo {
    color: #888;
    font-size: .93rem;
    margin-bottom: 28px;
  }

  .vol-filtros {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
    flex-wrap: wrap;
    align-items: center;
  }

  .vol-filtros input,
  .vol-filtros select {
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 9px 14px;
    font-size: .88rem;
    outline: none;
    transition: border .2s;
    background: #fff;
  }

  .vol-filtros input { flex: 1; min-width: 220px; }
  .vol-filtros input:focus,
  .vol-filtros select:focus { border-color: #696cff; }

  .btn-mis {
    background: #fff;
    border: 1px solid #696cff;
    color: #696cff;
    border-radius: 8px;
    padding: 9px 16px;
    font-size: .88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
    white-space: nowrap;
  }
  .btn-mis:hover       { background: #696cff; color: #fff; }
  .btn-mis.activo      { background: #696cff; color: #fff; }

  .btn-todos {
    background: #f3f4f6;
    border: 1px solid #ddd;
    color: #555;
    border-radius: 8px;
    padding: 9px 16px;
    font-size: .88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
    white-space: nowrap;
    display: none;
  }
  .btn-todos:hover { background: #e5e7eb; }

  .vol-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 18px;
  }

  .vol-card {
    background: #fff;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    padding: 20px;
    box-shadow: 0 1px 6px rgba(0,0,0,.06);
    transition: box-shadow .2s, transform .2s;
    cursor: pointer;
    position: relative;
  }
  .vol-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,.10);
    transform: translateY(-2px);
  }
  .vol-card.inscrito-card {
    border-color: #696cff;
    box-shadow: 0 0 0 2px rgba(105,108,255,.15);
  }

  .inscrito-ribbon {
    position: absolute;
    top: 12px; right: 12px;
    background: #696cff;
    color: #fff;
    font-size: .68rem;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 20px;
    letter-spacing: .4px;
  }

  .card-org {
    font-size: .72rem;
    font-weight: 600;
    color: #696cff;
    text-transform: uppercase;
    letter-spacing: .7px;
    margin-bottom: 4px;
  }

  .card-nombre {
    font-size: 1rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 10px;
    line-height: 1.3;
    padding-right: 70px;
  }

  .card-desc {
    font-size: .85rem;
    color: #888;
    line-height: 1.5;
    margin-bottom: 14px;
    display: -webkit-box;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 16px;
  }

  .meta-chip {
    font-size: .78rem;
    color: #666;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #f0f0f0;
    padding-top: 12px;
  }

  .estado-badge {
    font-size: .72rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    background: #dcfce7;
    color: #166534;
  }

  .match-chip {
    font-size: .72rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    background: #fef3c7;
    color: #92400e;
  }

  .btn-ver {
    background: #696cff;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 7px 16px;
    font-size: .82rem;
    font-weight: 600;
    cursor: pointer;
    transition: background .2s;
  }
  .btn-ver:hover { background: #5558e3; }

  .vol-empty {
    grid-column: 1/-1;
    text-align: center;
    padding: 60px 20px;
    color: #aaa;
  }
  .vol-empty .icon { font-size: 2.5rem; margin-bottom: 10px; }
  .vol-empty h3 { color: #555; font-size: 1rem; margin-bottom: 4px; }

  /* Modal */
  .modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,.4);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .modal-overlay.open { display: flex; }

  .modal-box {
    background: #fff;
    border-radius: 12px;
    max-width: 500px;
    width: 100%;
    max-height: 88vh;
    overflow-y: auto;
    box-shadow: 0 10px 40px rgba(0,0,0,.2);
  }

  .modal-head {
    padding: 20px 24px 16px;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .modal-head h2 { font-size: 1.05rem; font-weight: 700; color: #333; }
  .modal-head .m-org { font-size: .78rem; color: #696cff; font-weight: 600; margin-bottom: 4px; }
  .modal-close {
    background: none; border: none;
    font-size: 1.1rem; color: #aaa; cursor: pointer;
    padding: 0 4px; line-height: 1;
  }
  .modal-close:hover { color: #333; }

  .modal-body { padding: 20px 24px; }
  .m-section { margin-bottom: 16px; }
  .m-section h4 {
    font-size: .75rem; font-weight: 700; color: #696cff;
    text-transform: uppercase; letter-spacing: .6px; margin-bottom: 6px;
  }
  .m-section p { font-size: .88rem; color: #666; line-height: 1.6; }

  .cupo-bar-wrap { margin-top: 6px; }
  .cupo-bar-bg {
    background: #f3f4f6; border-radius: 20px; height: 8px; overflow: hidden;
  }
  .cupo-bar-fill {
    height: 100%; border-radius: 20px;
    background: #696cff; transition: width .4s;
  }
  .cupo-texto { font-size: .8rem; color: #888; margin-top: 4px; }

  .modal-footer {
    padding: 14px 24px 20px;
    display: flex; justify-content: flex-end; gap: 10px;
    border-top: 1px solid #f0f0f0;
  }
  .btn-cancelar {
    background: transparent; border: 1px solid #ddd;
    color: #888; border-radius: 6px; padding: 8px 16px;
    font-size: .85rem; cursor: pointer;
  }
  .btn-confirmar {
    background: #696cff; color: #fff; border: none;
    border-radius: 6px; padding: 8px 18px;
    font-size: .85rem; font-weight: 600; cursor: pointer;
    transition: background .2s;
  }
  .btn-confirmar:hover   { background: #5558e3; }
  .btn-confirmar:disabled {
    background: #9ca3af; cursor: not-allowed;
  }
  .btn-desinscribir {
    background: #fee2e2; color: #991b1b; border: none;
    border-radius: 6px; padding: 8px 18px;
    font-size: .85rem; font-weight: 600; cursor: pointer;
    transition: background .2s;
  }
  .btn-desinscribir:hover { background: #fecaca; }

  .toast-vol {
    position: fixed; bottom: 20px; right: 20px; z-index: 2000;
    background: #333; color: #fff;
    padding: 10px 18px; border-radius: 8px;
    font-size: .85rem;
    opacity: 0; transform: translateY(20px);
    transition: all .3s; pointer-events: none;
  }
  .toast-vol.show { opacity: 1; transform: translateY(0); }
</style>

<div class="vol-container">
  <h1 class="vol-titulo">Voluntariados</h1>
  <p class="vol-subtitulo">Explorá las oportunidades disponibles y encontrá la que más se ajusta a tu perfil.</p>

  <div class="vol-filtros">
    <input type="text" id="buscador" placeholder="Buscar por nombre u organización…" oninput="filtrar()">
    <select id="filtroProvincia" onchange="filtrar()">
      <option value="">Todas las provincias</option>
      <option>San José</option>
      <option>Alajuela</option>
      <option>Cartago</option>
      <option>Heredia</option>
      <option>Guanacaste</option>
      <option>Puntarenas</option>
      <option>Limón</option>
    </select>
    <button class="btn-mis" id="btnMis" onclick="toggleMisVoluntariados()">📋 Mis inscripciones</button>
    <button class="btn-todos" id="btnTodos" onclick="verTodos()">Ver todos</button>
  </div>

  <div class="vol-grid" id="volGrid">
    <div class="vol-empty">
      <div class="icon">⏳</div>
      <h3>Cargando voluntariados…</h3>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="cerrarFuera(event)">
  <div class="modal-box">
    <div class="modal-head">
      <div>
        <div class="m-org" id="mOrg"></div>
        <h2 id="mTitulo"></h2>
      </div>
      <button class="modal-close" onclick="cerrarModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="m-section">
        <h4>Descripción</h4>
        <p id="mDesc"></p>
      </div>
      <div class="m-section">
        <h4>Fechas</h4>
        <p id="mFechas"></p>
      </div>
      <div class="m-section">
        <h4>Ubicación</h4>
        <p id="mUbicacion"></p>
      </div>
      <div class="m-section" id="mReqSec">
        <h4>Requisitos</h4>
        <p id="mRequisitos"></p>
      </div>
      <div class="m-section">
        <h4>Contacto</h4>
        <p id="mContacto"></p>
      </div>
      <div class="m-section">
        <h4>Cupo disponible</h4>
        <div class="cupo-bar-wrap" id="cupoBarWrap">
          <div class="cupo-bar-bg">
            <div class="cupo-bar-fill" id="cupoBarFill" style="width:0%"></div>
          </div>
          <p class="cupo-texto" id="mCupo"></p>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancelar" onclick="cerrarModal()">Cerrar</button>
      <button class="btn-desinscribir" id="btnDesinscribir" style="display:none" onclick="desinscribirse()">Salir del voluntariado</button>
      <button class="btn-confirmar" id="btnConfirmar" onclick="confirmarInteres()">Inscribirme</button>
    </div>
  </div>
</div>

<div class="toast-vol" id="toast"></div>

<script>
  let voluntariados  = [];
  let misIds         = new Set(); // IDs de voluntariados en los que estoy inscrito
  let usuarioActual  = null;
  let volActual      = null;
  let vistaMis       = false;

  document.addEventListener('DOMContentLoaded', async () => {
    const raw = localStorage.getItem('usuario');
    if (raw) usuarioActual = JSON.parse(raw);
    await cargar();
  });

  /* ── Carga principal ── */
  async function cargar() {
    try {
      const res = await fetch('/api/voluntariados/activos');
      if (!res.ok) throw new Error();
      voluntariados = await res.json();

      // Cargar mis inscripciones si hay usuario
      if (usuarioActual?.id) {
        const r2 = await fetch(`/api/voluntariados/mis/${usuarioActual.id}`);
        if (r2.ok) {
          const mis = await r2.json();
          misIds = new Set(mis.map(v => v._id));
        }
      }

      render(voluntariados);
    } catch (e) {
      document.getElementById('volGrid').innerHTML = `
        <div class="vol-empty">
          <div class="icon">⚠️</div>
          <h3>No se pudieron cargar los voluntariados</h3>
          <p>Intentá de nuevo más tarde.</p>
        </div>`;
    }
  }

  /* ── Match ── */
  function matchPct(v) {
    if (!usuarioActual?.voluntario) return 0;
    const habs = (usuarioActual.habilidades || []).map(h => h.toLowerCase());
    if (!habs.length) return 0;
    const reqs = (v.requisitos || '').toLowerCase().split(/[,\n;]+/).map(r => r.trim()).filter(Boolean);
    if (!reqs.length) return 10;
    const hits = reqs.filter(r => habs.some(h => r.includes(h) || h.includes(r))).length;
    return Math.round((hits / reqs.length) * 100);
  }

  /* ── Render ── */
  function render(lista) {
    const grid = document.getElementById('volGrid');
    const activos = lista
      .filter(v => v.estado === 'activo')
      .map(v => ({ ...v, _m: matchPct(v), _inscrito: misIds.has(v._id) }))
      .sort((a, b) => b._inscrito - a._inscrito || b._m - a._m);

    if (!activos.length) {
      grid.innerHTML = `
        <div class="vol-empty">
          <div class="icon">🔍</div>
          <h3>${vistaMis ? 'No estás inscrito en ningún voluntariado' : 'No hay voluntariados disponibles'}</h3>
          <p>${vistaMis ? 'Explorá los disponibles y registrá tu interés.' : 'Revisá más tarde.'}</p>
        </div>`;
      return;
    }

    grid.innerHTML = activos.map(v => {
      const fi = v.fechaInicio ? new Date(v.fechaInicio).toLocaleDateString('es-CR') : '—';
      const ff = v.fechaFin    ? new Date(v.fechaFin).toLocaleDateString('es-CR')    : '—';
      const inscritos = (v.inscritos || []).length;
      const cupoTexto = v.cupoMaximo
        ? `👥 ${inscritos}/${v.cupoMaximo} cupos`
        : '👥 Sin límite';

      const matchHtml    = v._m >= 30 ? `<span class="match-chip">⭐ ${v._m}% match</span>` : '';
      const inscritoHtml = v._inscrito ? `<div class="inscrito-ribbon">✓ Inscrito</div>` : '';

      return `
        <div class="vol-card ${v._inscrito ? 'inscrito-card' : ''}" onclick="abrirModal('${v._id}')">
          ${inscritoHtml}
          <div class="card-org">${v.organizacion || 'FaunaLink'}</div>
          <div class="card-nombre">${v.nombre}</div>
          <p class="card-desc">${v.descripcion || 'Sin descripción.'}</p>
          <div class="card-meta">
            <span class="meta-chip">📅 ${fi} → ${ff}</span>
            <span class="meta-chip">📍 ${v.provincia || '—'}</span>
            <span class="meta-chip">${cupoTexto}</span>
          </div>
          <div class="card-footer">
            <div style="display:flex;gap:8px;align-items:center;">
              <span class="estado-badge">Activo</span>
              ${matchHtml}
            </div>
            <button class="btn-ver" onclick="event.stopPropagation();abrirModal('${v._id}')">Ver más</button>
          </div>
        </div>`;
    }).join('');
  }

  /* ── Filtros ── */
  function filtrar() {
    const q  = document.getElementById('buscador').value.toLowerCase();
    const pr = document.getElementById('filtroProvincia').value;
    const base = vistaMis
      ? voluntariados.filter(v => misIds.has(v._id))
      : voluntariados;
    render(base.filter(v =>
      (!q  || (v.nombre + ' ' + (v.organizacion || '')).toLowerCase().includes(q)) &&
      (!pr || v.provincia === pr)
    ));
  }

  function toggleMisVoluntariados() {
    if (!usuarioActual) { mostrarToast('Debes iniciar sesión'); return; }
    vistaMis = true;
    document.getElementById('btnMis').classList.add('activo');
    document.getElementById('btnTodos').style.display = 'block';
    render(voluntariados.filter(v => misIds.has(v._id)));
  }

  function verTodos() {
    vistaMis = false;
    document.getElementById('btnMis').classList.remove('activo');
    document.getElementById('btnTodos').style.display = 'none';
    filtrar();
  }

  /* ── Modal ── */
  function abrirModal(id) {
    const v = voluntariados.find(x => x._id === id);
    if (!v) return;
    volActual = v;

    document.getElementById('mOrg').textContent      = v.organizacion || 'FaunaLink';
    document.getElementById('mTitulo').textContent   = v.nombre;
    document.getElementById('mDesc').textContent     = v.descripcion || '—';
    document.getElementById('mContacto').textContent = v.contacto || '—';

    const fi = v.fechaInicio ? new Date(v.fechaInicio).toLocaleDateString('es-CR') : '—';
    const ff = v.fechaFin    ? new Date(v.fechaFin).toLocaleDateString('es-CR')    : '—';
    document.getElementById('mFechas').textContent = `${fi}  →  ${ff}`;

    const ub = [v.direccion, v.canton, v.provincia].filter(Boolean).join(', ');
    document.getElementById('mUbicacion').textContent = ub || '—';

    if (v.requisitos) {
      document.getElementById('mRequisitos').textContent = v.requisitos;
      document.getElementById('mReqSec').style.display = 'block';
    } else {
      document.getElementById('mReqSec').style.display = 'none';
    }

    // Barra de cupo
    const inscritos = (v.inscritos || []).length;
    if (v.cupoMaximo) {
      const pct = Math.min((inscritos / v.cupoMaximo) * 100, 100);
      document.getElementById('cupoBarFill').style.width = pct + '%';
      document.getElementById('cupoBarFill').style.background =
        pct >= 90 ? '#ef4444' : pct >= 60 ? '#f59e0b' : '#696cff';
      document.getElementById('mCupo').textContent =
        `${inscritos} de ${v.cupoMaximo} cupos ocupados`;
      document.getElementById('cupoBarWrap').style.display = 'block';
    } else {
      document.getElementById('mCupo').textContent = 'Sin límite de cupos';
      document.getElementById('cupoBarWrap').style.display = 'none';
    }

    // Botones según estado de inscripción
    const estaInscrito = misIds.has(v._id);
    document.getElementById('btnConfirmar').style.display    = estaInscrito ? 'none'  : 'block';
    document.getElementById('btnDesinscribir').style.display = estaInscrito ? 'block' : 'none';

    // Deshabilitar si cupo lleno
    if (v.cupoMaximo && inscritos >= v.cupoMaximo && !estaInscrito) {
      document.getElementById('btnConfirmar').disabled    = true;
      document.getElementById('btnConfirmar').textContent = 'Sin cupos';
    } else {
      document.getElementById('btnConfirmar').disabled    = false;
      document.getElementById('btnConfirmar').textContent = 'Inscribirme';
    }

    document.getElementById('modalOverlay').classList.add('open');
  }

  function cerrarModal() {
    document.getElementById('modalOverlay').classList.remove('open');
    volActual = null;
  }

  function cerrarFuera(e) {
    if (e.target === document.getElementById('modalOverlay')) cerrarModal();
  }

  /* ── Inscripción ── */
  async function confirmarInteres() {
    if (!usuarioActual) { mostrarToast('Debes iniciar sesión'); return; }
    try {
      const res = await fetch(`/api/voluntariados/${volActual._id}/inscribir`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: usuarioActual.id })
      });
      const data = await res.json();
      if (!res.ok) { mostrarToast('⚠️ ' + data.message); return; }
      misIds.add(volActual._id);
      mostrarToast('✅ ' + data.message);
      cerrarModal();
      await cargar();
    } catch (e) {
      mostrarToast('⚠️ Error al inscribirse');
    }
  }

  /* ── Desinscripción ── */
  async function desinscribirse() {
    if (!usuarioActual) return;
    try {
      const res = await fetch(`/api/voluntariados/${volActual._id}/desinscribir`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: usuarioActual.id })
      });
      const data = await res.json();
      if (!res.ok) { mostrarToast('⚠️ ' + data.message); return; }
      misIds.delete(volActual._id);
      mostrarToast('✅ ' + data.message);
      cerrarModal();
      await cargar();
    } catch (e) {
      mostrarToast('⚠️ Error al salir del voluntariado');
    }
  }

  /* ── Toast ── */
  function mostrarToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }
</script>